                     </image>
                  </ImageView>
               </graphic>
            </Button>
            <Button fx:id="btn_grabar" contentDisplay="TOP" layoutX="410.0" layoutY="6.0" mnemonicParsing="false" onAction="#acc_grabar" prefHeight="70.0" prefWidth="70.0" text="%btn.grabar">
