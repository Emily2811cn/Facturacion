<AnchorPane id="AnchorPane" prefHeight="382.0" prefWidth="580.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="upse.facturacion.controlador.ClienteController">
