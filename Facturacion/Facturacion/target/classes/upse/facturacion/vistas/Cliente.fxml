               </children>
            </Pane>

            <Label layoutX="52.0" layoutY="83.0" text="%lbl.cedula">
               <font> <Font name="System Bold" size="12.0" /> </font>
            </Label>
            <TextField fx:id="txt_cedula" layoutX="128.0" layoutY="79.0" prefHeight="25.0" prefWidth="242.0" />

            <Label layoutX="52.0" layoutY="117.0" text="%lbl.nombres">
               <font> <Font name="System Bold" size="12.0" /> </font>
            </Label>
            <TextField fx:id="txt_nombres" layoutX="128.0" layoutY="113.0" prefHeight="25.0" prefWidth="242.0" />

            <Label layoutX="52.0" layoutY="156.0" text="%lbl.direccion">
