               <image>
                  <Image url="@../recursos/tiendita.png" />
               </image>
            </ImageView>
            <Text fill="WHITE" layoutX="32.0" layoutY="256.0" strokeType="OUTSIDE" strokeWidth="0.0" text="%lbl.tituloPrincipal" textAlignment="CENTER" wrappingWidth="250.2109375">
               <font>
                  <Font name="System Bold" size="30.0" />
               </font>
            </Text>
            <ComboBox fx:id="cbx_idioma" layoutX="82.0" layoutY="337.0" prefWidth="150.0" />
         </children>
      </Pane>

      <Pane prefHeight="400.0" prefWidth="300.0" style="-fx-background-color: #366600;">
         <children>
            <ImageView fitHeight="124.0" fitWidth="122.0" layoutX="89.0" layoutY="23.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../recursos/ico.png" />
