               </font>
            </Text>
            <PasswordField fx:id="txt_clave" layoutX="63.0" layoutY="239.0" prefHeight="30.0" prefWidth="182.0" />
            
            <Button fx:id="btn_login" layoutX="63.0" layoutY="311.0" mnemonicParsing="false" onAction="#acc_login" prefHeight="40.0" prefWidth="85.0" text="%btn.acceder" />
            <Button fx:id="btn_cancelar" layoutX="160.0" layoutY="311.0" mnemonicParsing="false" onAction="#acc_cancelar" prefHeight="40.0" prefWidth="85.0" text="%btn.cancelar" />
