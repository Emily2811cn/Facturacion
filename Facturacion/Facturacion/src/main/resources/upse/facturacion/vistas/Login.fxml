            <TextField fx:id="txt_usuario" layoutX="63.0" layoutY="180.0" prefHeight="30.0" prefWidth="182.0" />
            
            <Text fill="WHITE" layoutX="63.0" layoutY="235.0" strokeType="OUTSIDE" strokeWidth="0.0" text="%lbl.clave">
